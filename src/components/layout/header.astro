---
import { navItems } from '../../data/nav';
import { site } from '../../data/site';
import ThemeToggle from './theme-toggle.astro';
---

<header
  class="fixed top-5 left-1/2 z-50 -translate-x-1/2"
  aria-label="Primary navigation"
>
  <nav
    class="flex items-center gap-1 rounded-full border border-white/8 bg-background/40 p-1 shadow-2xl shadow-black/30 backdrop-blur-xl backdrop-saturate-150"
  >
    <a
      href="/"
      class="flex h-8 items-center rounded-full px-3 text-sm font-medium tracking-tight text-foreground transition hover:bg-white/6"
      aria-label={`${site.name} — home`}
    >
      {site.initials}
    </a>

    <span aria-hidden="true" class="mx-0.5 h-4 w-px border-white/8"></span>

    {
      navItems.map((item) => (
        <a
          href={item.href}
          class="text-muted-foreground hover:text-foreground flex h-8 items-center rounded-full px-3 text-sm transition hover:bg-white/6"
        >
          {item.label}
        </a>
      ))
    }

    <span aria-hidden="true" class="mx-0.5 h-4 w-px border-white/"></span>

    <ThemeToggle />
  </nav>
</header>
