---
import { stackCategories } from '../../data/stack';
import SectionTitle from '../ui/section-title.astro';
---

<section class="p-4">
  <SectionTitle>Workbench</SectionTitle>

  <ul class="flex flex-col gap-3 font-mono text-sm">
    {
      stackCategories.map((category) => (
        <li class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-4">
          <span class="text-muted-foreground shrink-0 text-xs tracking-widest uppercase sm:w-28">
            // {category.name}
          </span>
          <span class="text-foreground">{category.items.join(' · ')}</span>
        </li>
      ))
    }
  </ul>
</section>
