---
import { Icon } from 'astro-icon/components';
import { profile } from '../../data/profile';
import EncryptedContact from './encrypted-contact.astro';
import InfoItem from './item.astro';
import ViewerClock from './viewer-clock.astro';
---

<div class="space-y-2.5 p-4 text-sm text-foreground">
  <InfoItem icon="lucide:code-xml">{profile.role}</InfoItem>

  <div class="grid gap-x-8 gap-y-3 sm:grid-cols-2">
    <InfoItem icon="lucide:phone">
      <EncryptedContact
        value={profile.phone}
        prefix="tel:"
        class="font-mono transition hover:text-foreground"
      />
    </InfoItem>

    <InfoItem icon="lucide:mail">
      <EncryptedContact
        value={profile.email}
        prefix="mailto:"
        class="transition hover:text-foreground"
      />
    </InfoItem>

    <InfoItem icon="lucide:mars">{profile.pronouns}</InfoItem>

    <InfoItem icon="lucide:clock">
      <ViewerClock ownerTimezone={profile.timezone} />
    </InfoItem>
  </div>

  <ul class="mt-4 flex items-center gap-1.5">
    {
      profile.socials.map((s) => (
        <li>
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={s.label}
            class="border-border bg-muted/60 text-muted-foreground hover:border-primary/60 hover:bg-muted hover:text-foreground flex size-10 items-center justify-center rounded-full border transition hover:-translate-y-0.5"
          >
            <Icon name={s.icon} class="size-5" />
          </a>
        </li>
      ))
    }
  </ul>
</div>
