---
import { experiences } from '../../data/experience';
import ExperienceCard from './experience-card.tsx';

const sorted = [...experiences].sort((a, b) => {
  const aCurrent = a.endDate === 'present';
  const bCurrent = b.endDate === 'present';
  if (aCurrent && !bCurrent) return -1;
  if (!aCurrent && bCurrent) return 1;
  const aKey = aCurrent ? a.startDate : a.endDate;
  const bKey = bCurrent ? b.startDate : b.endDate;
  return bKey.localeCompare(aKey);
});
---

<ul class="flex flex-col">
  {
    sorted.map((exp, i) => (
      <li class="border-border border-b last:border-b-0">
        <ExperienceCard client:visible experience={exp} defaultOpen={i === 0} />
      </li>
    ))
  }
</ul>
