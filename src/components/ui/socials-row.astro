---
import { Icon } from 'astro-icon/components';
import { profile } from '../../data/profile';
---

{
  profile.socials.map((s, i) => (
    <>
      {i > 0 && <span class="h-px flex-1 bg-border" />}
      <a
        href={s.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={s.label}
        class="hover:text-foreground flex shrink-0 items-center gap-1.5 px-2 transition"
      >
        <Icon name={s.icon} class="size-4" />
        <span class="lowercase">{s.label}</span>
      </a>
    </>
  ))
}
