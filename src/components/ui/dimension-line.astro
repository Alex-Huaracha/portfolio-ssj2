---
import { Icon } from 'astro-icon/components';
import { profile } from '../../data/profile';
---

<div
  class="flex h-10 items-center px-4 font-mono text-xs text-muted-foreground"
>
  <span class="h-3 w-px shrink-0 bg-border"></span>
  <span class="h-px flex-1 bg-border"></span>

  {
    profile.socials.map((s) => (
      <>
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={s.label}
          class="hover:text-foreground flex shrink-0 items-center gap-1.5 px-2 transition"
        >
          <Icon name={s.icon} class="size-4" />
          <span class="lowercase">{s.label}</span>
        </a>
        <span class="bg-border h-px flex-1" />
      </>
    ))
  }

  <span class="h-3 w-px shrink-0 bg-border"></span>
</div>
