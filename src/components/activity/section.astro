---
import { profile } from '../../data/profile';
import TraceBrackets from '../ui/trace-brackets.astro';

interface Day {
  date: string;
  count: number;
  level: 0 | 1 | 2 | 3 | 4;
}

let contributions: Day[] = [];
let total = 0;

try {
  const res = await fetch(
    `https://github-contributions-api.jogruber.de/v4/${profile.githubUsername}?y=last`,
  );
  if (res.ok) {
    const data = await res.json();
    contributions = data.contributions ?? [];
    total = data.total?.lastYear ?? 0;
  }
} catch {
  // fallback: empty grid
}

// Pad start so rows align to days of the week (Sunday-first like GitHub)
const firstDayOfWeek = contributions[0]
  ? new Date(contributions[0].date).getUTCDay()
  : 0;
const padded: (Day | null)[] = [
  ...Array(firstDayOfWeek).fill(null),
  ...contributions,
];

// Chunk into weeks (columns of 7)
const weeks: (Day | null)[][] = [];
for (let i = 0; i < padded.length; i += 7) {
  weeks.push(padded.slice(i, i + 7));
}

const MONTHS = [
  'JAN',
  'FEB',
  'MAR',
  'APR',
  'MAY',
  'JUN',
  'JUL',
  'AUG',
  'SEP',
  'OCT',
  'NOV',
  'DEC',
];

const monthOfWeek = (week: (Day | null)[]): number | null => {
  const firstDay = week.find((d): d is Day => d !== null);
  return firstDay ? new Date(firstDay.date).getUTCMonth() : null;
};

const MIN_WEEKS_TO_LABEL = 3;

const monthLabels: (string | null)[] = weeks.map((week, i) => {
  const month = monthOfWeek(week);
  if (month === null) return null;

  const prevWeek = i === 0 ? null : weeks[i - 1];
  const prevMonth = prevWeek ? monthOfWeek(prevWeek) : null;
  if (prevMonth === month) return null;

  // Skip label if the month doesn't span enough weeks to fit the text
  let span = 1;
  for (let j = i + 1; j < weeks.length; j++) {
    const next = weeks[j];
    if (!next || monthOfWeek(next) !== month) break;
    span++;
  }
  return span >= MIN_WEEKS_TO_LABEL ? (MONTHS[month] ?? null) : null;
});

const dayLabels = ['', 'MON', '', 'WED', '', 'FRI', ''];

const RECENT_WEEKS = 26;
const splitIdx = Math.max(0, weeks.length - RECENT_WEEKS);

const levelClass: Record<Day['level'], string> = {
  0: 'bg-muted/60',
  1: 'bg-foreground/25',
  2: 'bg-foreground/45',
  3: 'bg-foreground/70',
  4: 'bg-foreground/95',
};

const formatPeriod = (date: string | undefined) => {
  if (!date) return '—';
  const [y, m] = date.split('-');
  return `${y}.${m}`;
};

const period = `${formatPeriod(contributions[0]?.date)} → ${formatPeriod(contributions[contributions.length - 1]?.date)}`;

const legendLevels: Day['level'][] = [0, 1, 2, 3, 4];
---

<section class="p-4">
  <dl
    class="mb-3 grid grid-cols-[auto_1fr] gap-x-4 gap-y-0.5 font-mono text-xs"
  >
    <dt class="tracking-widest text-muted-foreground uppercase">Period</dt>
    <dd class="text-foreground">{period}</dd>
    <dt class="tracking-widest text-muted-foreground uppercase">Commits</dt>
    <dd class="text-foreground">{total}</dd>
    <dt class="tracking-widest text-muted-foreground uppercase">Username</dt>
    <dd class="text-foreground">{profile.githubUsername}</dd>
  </dl>

  <div class="relative w-full p-2">
    <TraceBrackets />
    <div
      class="grid grid-cols-[auto_auto] gap-x-2 font-mono text-[10px] tracking-widest text-muted-foreground"
    >
      <div></div>
      <div class="mb-1 flex gap-0.5 tracking-normal">
        {
          monthLabels.map((label, i) => (
            <span
              class:list={[
                'w-2 sm:w-2.5 shrink-0 whitespace-nowrap',
                i < splitIdx && 'hidden md:inline-block',
              ]}
            >
              {label ?? ''}
            </span>
          ))
        }
      </div>
      <div class="flex flex-col gap-0.5">
        {
          dayLabels.map((label) => (
            <span class="h-2 leading-none sm:h-2.5">{label}</span>
          ))
        }
      </div>
      <div class="flex gap-0.5">
        {
          weeks.map((week, i) => (
            <div
              class:list={[
                'flex-col gap-0.5',
                i < splitIdx ? 'hidden md:flex' : 'flex',
              ]}
            >
              {week.map((day) =>
                day ? (
                  <div
                    class:list={[
                      'size-2 sm:size-2.5 hover:ring-1 hover:ring-foreground',
                      levelClass[day.level],
                    ]}
                    title={`${day.count} contributions on ${day.date}`}
                  />
                ) : (
                  <div class="size-2 sm:size-2.5" />
                ),
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div
    class="mt-3 flex items-center justify-end gap-1.5 font-mono text-[10px] tracking-widest text-muted-foreground"
  >
    <span>LESS</span>
    {
      legendLevels.map((level) => (
        <span class:list={['size-2 sm:size-2.5', levelClass[level]]} />
      ))
    }
    <span>MORE</span>
  </div>
</section>
