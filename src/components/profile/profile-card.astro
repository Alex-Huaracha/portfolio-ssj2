---
import { cn } from '@/lib/utils';
import { profile } from '../../data/profile';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<article
  class={cn(
    'relative overflow-hidden rounded-2xl border border-border bg-card/60 shadow-2xl backdrop-blur-xl backdrop-saturate-150',
    className,
  )}
>
  <div
    class="relative h-48 w-full bg-linear-to-br from-primary via-secondary to-primary/70"
  >
    <div aria-hidden="true"><slot name="banner" /></div>
    <div
      class="absolute top-3 right-4 font-mono text-[10px] tracking-[0.2em] text-primary uppercase"
    >
      available · {profile.location}
    </div>
  </div>

  <div class="relative -mt-16 pb-6 sm:px-8 sm:pb-8">
    <slot />
  </div>
</article>
