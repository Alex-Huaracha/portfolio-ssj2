---
import { cn } from '@/lib/utils';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<article
  class={cn(
    'relative overflow-hidden rounded-2xl border border-white/8 bg-background/40 shadow-2xl shadow-black/30 backdrop-blur-xl backdrop-saturate-150',
    className,
  )}
>
  <div class="h-48 w-full" aria-hidden="true">
    <slot name="banner" />
  </div>

  <div class="relative -mt-16 pb-6 sm:px-8 sm:pb-8">
    <slot />
  </div>
</article>
