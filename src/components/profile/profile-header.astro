---
import { Icon } from 'astro-icon/components';
import { profile } from '../../data/profile';
---

<div class="px-4 sm:px-0">
  <div class="flex items-end justify-between gap-3">
    <div class="relative w-fit">
      <div
        class="flex h-30 w-30 items-center justify-center rounded-full border-4 border-background bg-linear-to-br from-primary to-secondary text-4xl font-semibold text-primary-foreground shadow-xl sm:h-40 sm:w-40"
        aria-label={`${profile.name} avatar`}
      >
        {profile.initials}
      </div>
      <span
        class="absolute right-2 bottom-2 h-5 w-5 rounded-full bg-emerald-500 ring-4 ring-background sm:h-6 sm:w-6"
        aria-label="online"></span>
    </div>

    <ul class="flex items-center gap-1.5 pb-2">
      {
        profile.socials.map((s) => (
          <li>
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="border-border bg-muted/60 text-muted-foreground hover:border-primary/60 hover:bg-muted hover:text-foreground flex size-12 items-center justify-center rounded-full border transition hover:-translate-y-0.5"
            >
              <Icon name={s.icon} class="size-6" />
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="mt-4">
    <h1 class="text-3xl font-semibold tracking-tight">
      {profile.name}
    </h1>
  </div>
</div>
