---
import { profile } from '../../data/profile';
import ProfileStatus from './status.astro';
---

<div>
  <div class="trace-h"></div>

  <div class="flex">
    <div class="shrink-0 mx-0.5 my-0.75">
      <div
        class="relative flex size-30 items-center justify-center rounded-full bg-linear-to-br from-primary to-secondary text-3xl font-semibold text-primary-foreground sm:size-40"
        aria-label={`${profile.name} avatar`}
      >
        {profile.initials}
        <span
          class="online-dot absolute right-1.5 bottom-1.5 h-4 w-4 ring-4 ring-background sm:h-5 sm:w-5"
          aria-label="online"></span>
      </div>
    </div>

    <div class="trace-v"></div>

    <div class="flex flex-1 flex-col">
      <div class="flex grow items-end pb-1 pl-4">
        <span
          aria-hidden="true"
          class="block font-mono text-xs tracking-tight text-muted-foreground/60 select-none max-sm:hidden"
        >
          text-3xl text-foreground font-semibold
        </span>
      </div>

      <div class="border-t">
        <h1 class="pl-4 text-3xl font-semibold tracking-tight">
          {profile.name}
        </h1>

        <div class="border-t">
          <ProfileStatus />
        </div>
      </div>
    </div>
  </div>

  <div class="trace-h"></div>
</div>
